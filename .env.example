# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=false

# Database
DATABASE_URL=sqlite:///instance/foundation_complete.db

# JWT Secret Key (REQUIRED - generate a strong random key)
SECRET_KEY=your-secret-key-here-generate-a-strong-random-string

# Super Admin
SUPERADMIN_INITIAL_PASSWORD= superadmin123

# Google OAuth (REQUIRED for Google login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# Frontend URL (REQUIRED for redirects)
FRONTEND_URL=http://localhost:3000

# Africa's Talking SMS
AFRICASTALKING_USERNAME=your_username
AFRICASTALKING_API_KEY=your_api_key
AFRICASTALKING_SENDER_ID=MBOGO

# Email (SMTP) — works with Gmail, SendGrid, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@mbogofoundation.org

# App URL (used in email links)
APP_URL=https://foundation-drab-eta.vercel.app
